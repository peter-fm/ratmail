# Copy to ~/.config/ratmail/ratmail.toml (or $XDG_CONFIG_HOME/ratmail/ratmail.toml)
# and fill in your SMTP credentials.
# Keep this file private (do not commit).
# Multi-account format:
[[accounts]]
name = "Personal"
# Relative paths are stored under ~/.local/state/ratmail (or $XDG_STATE_HOME/ratmail)
db_path = "ratmail-personal.db"

[accounts.smtp]
host = "smtp.example.com"
port = 587
username = "user@example.com"
password = "app-password-or-smtp-password"
from = "Your Name <user@example.com>"

[accounts.imap]
host = "imap.example.com"
port = 993
username = "user@example.com"
password = "app-password-or-imap-password"
skip_tls_verify = false
initial_sync_days = 90
fetch_chunk_size = 10

# Add more accounts by repeating [[accounts]] blocks.

[render]
remote_images = false
width_px = 800
render_scale = 1.5
tile_height_px_side = 1000
tile_height_px_focus = 60

[ui]
folder_width_cols = 25

[cli]
enabled = false
mode = "readonly"
default_account = "Personal"

[cli.acl]
# If [cli.acl] is omitted, reads are unscoped by account or folder.
accounts = ["Personal"]
folders = ["INBOX"]
from_allow = ["*@example.com"]
fields = ["id", "folder_id", "date", "from", "subject", "unread"]
allow_body = false
allow_raw = false
allow_attachments = false
# allow_commands = ["messages.list", "message.get"]
# deny_commands = ["message.delete", "message.move", "send"]
# allow_move = false
# allow_delete = false
# allow_mark = false
# allow_send = false

# Preset: Agent-safe (locked down)
#
# [cli]
# enabled = true
# mode = "readonly"
# default_account = "Personal"
#
# [cli.acl]
# accounts = ["Personal"]
# folders = ["INBOX"]
# from_allow = ["*@trusted.com"]
# fields = ["id", "folder_id", "date", "from", "subject", "unread"]
# allow_commands = ["accounts.list", "folders.list", "messages.list", "message.get"]
# allow_body = false
# allow_raw = false
# allow_attachments = false
# allow_move = false
# allow_delete = false
# allow_mark = false
# allow_send = false

# Preset: Full access (use with care)
#
# [cli]
# enabled = true
# mode = "full-access"
# default_account = "Personal"
#
# [cli.acl]
# accounts = ["*"]
# folders = ["*"]
# from_allow = ["*"]
